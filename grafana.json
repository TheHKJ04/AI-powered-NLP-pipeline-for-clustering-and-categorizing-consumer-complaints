{
  "dashboard": {
    "title": "Complaint System Monitoring",
    "panels": [
      {
        "type": "graph",
        "title": "Backend Request Latency",
        "targets": [{ "expr": "http_request_duration_seconds_bucket" }]
      },
      {
        "type": "graph",
        "title": "Backend Error Rate",
        "targets": [{ "expr": "http_requests_total{endpoint=\"/predict\"}" }]
      },
      {
        "type": "graph",
        "title": "Backend Request Count",
        "targets": [{ "expr": "http_requests_total" }]
      },
      {
        "type": "graph",
        "title": "Frontend Availability",
        "targets": [{ "expr": "up{job=\"streamlit_frontend\"}" }]
      }
    ]
  }
}
